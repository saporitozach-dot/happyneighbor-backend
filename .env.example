# ===========================================
# Backend (api-server.js) - Copy to .env
# ===========================================

# Production frontend URL - required for CORS and redirects
# Example: https://your-app.netlify.app or https://happyneighbor.com
FRONTEND_URL=http://localhost:3000

# Session secret - generate with: openssl rand -base64 32
# Required for production; change from default in dev too
SESSION_SECRET=your-secret-key-change-this

# Port - hosting platforms (Railway, Render) set this automatically
PORT=3005

# Optional: Email (for verification emails, payment confirmations)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Optional: Stripe (for premium payments)
# STRIPE_SECRET_KEY=
# VITE_STRIPE_PUBLISHABLE_KEY= (set in frontend build env)

# ===========================================
# Frontend (Vite build) - set in Netlify/Vercel
# ===========================================
# VITE_API_URL=https://your-api.railway.app/api
